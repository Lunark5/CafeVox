# Asset meta data rules
# Never ignore asset meta files as they link files to your Unity GUID system
!/[Aa]ssets/**/*.meta

# Packaging and Addressables Data 
# (Uncomment the line below if you are using Addressables and don't want local build data tracked)
# /[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# TextMeshPro and embedded package caches
/[Aa]ssets/StreamingAssets/aa.meta
/[Aa]ssets/StreamingAssets/aa/*

